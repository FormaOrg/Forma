{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd Frontend && npm install",
  "buildCommand": "cd Frontend && npm run build",
  "outputDirectory": "Frontend/dist/Frontend/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
